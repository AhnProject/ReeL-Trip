# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# JWT
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=86400000

# OpenAI (for embeddings and query parsing)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server
PORT=4000
API_BASE_URL=http://localhost:4000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
ALLOWED_ORIGIN_SUFFIXES=

# Claude API (for travel info extraction)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Apify (Instagram Reels scraper)
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
