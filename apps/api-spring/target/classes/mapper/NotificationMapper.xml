<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.reeltrip.api.notification.mapper.NotificationMapper">

    <resultMap id="notificationResultMap" type="com.reeltrip.api.notification.model.Notification">
        <id     property="id"             column="id"/>
        <result property="userId"         column="user_id"/>
        <result property="message"        column="message"/>
        <result property="type"           column="type"/>
        <result property="relatedSpaceId" column="related_space_id"/>
        <result property="isRead"         column="is_read"/>
        <result property="createdAt"      column="created_at"/>
        <result property="readAt"         column="read_at"/>
    </resultMap>

    <select id="findByUserId" resultMap="notificationResultMap">
        SELECT id, user_id, message, type, related_space_id, is_read, created_at, read_at
        FROM notifications
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <select id="findById" resultMap="notificationResultMap">
        SELECT id, user_id, message, type, related_space_id, is_read, created_at, read_at
        FROM notifications
        WHERE id = #{id}
    </select>

    <update id="markAsRead">
        UPDATE notifications
        SET is_read = TRUE, read_at = NOW()
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM notifications WHERE id = #{id}
    </delete>

</mapper>
