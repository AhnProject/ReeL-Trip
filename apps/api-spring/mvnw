#!/bin/sh
# Maven Wrapper Script
# Licensed to the Apache Software Foundation (ASF) under one or more
# contributor license agreements. See the NOTICE file for details.

set -e

MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"
MAVEN_PROJECTBASEDIR="$(pwd)"

# Locate the Maven binary — prefer wrapper download, fall back to system mvn
if [ -f "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" ]; then
  WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
  exec "$JAVA_HOME/bin/java" \
    -cp "$WRAPPER_JAR" \
    "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
    org.apache.maven.wrapper.MavenWrapperMain "$@"
else
  # Fallback: use system Maven
  if command -v mvn >/dev/null 2>&1; then
    exec mvn "$@"
  else
    echo "ERROR: Neither Maven Wrapper jar nor system mvn found." >&2
    echo "Run: mvn wrapper:wrapper  to generate the wrapper jar." >&2
    exit 1
  fi
fi
