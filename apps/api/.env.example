# API server environment variables.
#
# NOTE: The backend is deployed to Railway and these variables are managed there.
# You only need a local `.env` if you are running the NestJS server locally
# (e.g. for backend development). Frontend devs should point the web/mobile apps
# at the Railway URL instead — see apps/web/.env.example.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=86400s
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PORT=4000
API_BASE_URL=http://localhost:4000
# 쉼표로 구분, 프론트엔드/모바일 origin을 모두 추가할 것
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
