# Web app environment variables.
# Copy this file to `.env.local` and adjust as needed. `.env.local` is gitignored.

# Backend API base URL. Production backend is deployed to Railway.
NEXT_PUBLIC_API_URL=https://reel-tripapi-production.up.railway.app

# This web app's own URL (used for CORS / Server Actions allowlist).
NEXT_PUBLIC_APP_URL=http://localhost:5173
