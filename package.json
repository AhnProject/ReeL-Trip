{
  "name": "reel-trip",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=!./apps/mobile",
    "dev": "turbo run dev --filter=!./apps/mobile",
    "lint": "turbo run lint --filter=!./apps/mobile",
    "type-check": "turbo run type-check --filter=!./apps/mobile",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "overrides": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  }
}
